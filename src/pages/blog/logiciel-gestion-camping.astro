---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import SubpageHeader from '../../components/SubpageHeader.astro';
import {
  SITE_URL,
  crmSoftwareApplication,
  buildBreadcrumb,
  buildWebPage,
} from '../../data/schema';

const title = 'Logiciel de gestion camping au Québec · Camplo';
const description =
  "Camplo est un logiciel de gestion camping (CRM / PMS) conçu au Québec : tableau de bord, calendrier, réservations, clients, fiscalité TPS/TVQ. Application desktop, base de données dédiée par camping.";
const pageUrl = `${SITE_URL}/blog/logiciel-gestion-camping/`;

const datePublished = '2026-04-25';
const datePublishedLabel = new Intl.DateTimeFormat('fr-CA', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(`${datePublished}T12:00:00`));

const pageJsonLd = [
  crmSoftwareApplication,
  buildWebPage({
    url: pageUrl,
    name: title,
    description,
    about: `${SITE_URL}/#crm`,
    datePublished,
    dateModified: '2026-04-25',
  }),
  buildBreadcrumb([
    { name: 'Camplo', url: `${SITE_URL}/` },
    { name: 'Blog', url: `${SITE_URL}/blog/` },
    { name: 'Logiciel de gestion camping', url: pageUrl },
  ]),
];
---

<Layout
  title={title}
  description={description}
  canonicalPath="/blog/logiciel-gestion-camping/"
  ogImageAlt="Camplo CRM : logiciel de gestion camping desktop pour campings québécois"
  includeFaqJsonLd={false}
  includeProductPreloads={false}
  pageJsonLd={pageJsonLd}
>
  <SubpageHeader backHref="/blog/" backLabel="Retour aux articles" />

  <main class="subpage">
    <article class="article">
      <p class="eyebrow">Produit · Logiciel de gestion camping</p>
      <h1 class="title">
        Le <em>logiciel de gestion camping</em> conçu pour les campings québécois
      </h1>
      <p class="article-meta">
        Publié le <time datetime={datePublished}>{datePublishedLabel}</time>
      </p>

      <p class="lede">
        Camplo CRM est l'application desktop qui remplace vos cahiers, vos
        chiffriers Excel et les logiciels génériques pas faits pour le camping.
        Réservations, emplacements, clients, taxes TPS/TVQ : tout ce qu'il faut
        pour opérer une saison, sans navigateur, sans commission.
      </p>

      <section class="section">
        <h2>Un logiciel de gestion camping (CRM) pensé pour le Québec</h2>
        <p>
          La plupart des logiciels de gestion camping (PMS, Property Management
          System) sont des outils américains traduits à moitié, ou des SaaS
          génériques qui ne comprennent rien aux saisons courtes, aux
          emplacements saisonniers, aux taxes québécoises ni à la réalité d'un
          camping indépendant. Camplo a été conçu ici, par et pour des
          opérateurs de camping du Québec.
        </p>
        <ul class="features">
          <li>Tableau de bord temps réel : arrivées, départs, occupation</li>
          <li>Calendrier mensuel : toutes les réservations par emplacement</li>
          <li>Réservations filtrables par date, statut, emplacement</li>
          <li>Gestion d'emplacements et de services (eau, électricité, égout)</li>
          <li>Fichiers clients avec historique complet</li>
          <li>Fiscalité TPS/TVQ intégrée et conforme</li>
        </ul>
      </section>

      <section class="section">
        <h2>Une vraie application, votre base à vous</h2>
        <p>
          Camplo CRM s'installe comme une <strong>application sur le poste de
          la réception</strong>, pas un onglet de navigateur de plus à garder
          ouvert. Chaque camping a sa propre base de données, isolée des
          autres et hébergée par nous. Vos réservations, vos clients et votre
          historique restent les vôtres : vous n'êtes pas un compte anonyme
          parmi des milliers sur une plateforme géante.
        </p>
      </section>

      <section class="section">
        <h2>Aucune commission, jamais</h2>
        <p>
          Contrairement aux plateformes de réservation qui prennent 10 à 20 %
          par transaction, Camplo fonctionne avec un <strong>abonnement
          mensuel fixe</strong>. Vous savez d'avance ce que vous payez, peu
          importe le volume. Sur 200 réservations à 200 $, ça fait la
          différence entre payer 8 000 $ de commissions ou un montant fixe
          mensuel.
        </p>
      </section>

      <section class="section">
        <h2>Couplé avec un site de réservation en ligne</h2>
        <p>
          Camplo CRM se branche directement sur le site de réservation en
          ligne Camplo. Vos campeurs réservent et paient en ligne, la
          réservation apparaît dans votre tableau de bord, le courriel de
          confirmation part automatiquement. Aucune double saisie, aucun
          oubli, zéro frottement.
        </p>
        <p>
          <a class="inline-cta" href="/">Voir tous les produits Camplo →</a>
        </p>
      </section>

      <section class="section cta-card">
        <h2>Discutons de votre camping</h2>
        <p>
          Chaque camping est différent. Nous adaptons Camplo à votre
          opération : nombre d'emplacements, saisonniers vs voyageurs,
          services particuliers. Écrivez-nous, on en discute.
        </p>
        <div class="cta-row">
          <a class="pill pill--primary" href="mailto:adamauger872@gmail.com">
            Écrivez-nous
            <svg class="pill-arrow" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
              <path d="M4 10 L10 4 M5 4 L10 4 L10 9" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a class="pill pill--ghost" href="tel:5817480161">
            581-748-0161
            <svg class="pill-arrow" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
              <path d="M4 10 L10 4 M5 4 L10 4 L10 9" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </section>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .subpage {
    background: var(--paper);
    padding: clamp(40px, 6vw, 80px) 0 clamp(60px, 8vw, 120px);
    min-height: 60vh;
  }

  .article {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 var(--wrap-pad-x);
  }

  .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
    margin-bottom: 18px;
  }

  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5vw, 60px);
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--ink);
    margin: 0 0 14px;
  }
  .title em {
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
  }

  .article-meta {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.02em;
    color: var(--ink-muted);
    margin: 0 0 32px;
  }
  .article-meta time {
    color: var(--ink-soft);
  }

  .lede {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.45;
    color: var(--ink-soft);
    margin: 0 0 48px;
    max-width: 60ch;
  }

  .section {
    margin-top: clamp(40px, 5vw, 64px);
  }

  .section h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(24px, 2.6vw, 32px);
    letter-spacing: -0.015em;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 16px;
  }

  .section p {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(15px, 1.05vw, 17px);
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 0 0 14px;
    max-width: 62ch;
  }

  .section p strong {
    color: var(--ink);
    font-weight: 700;
  }

  .features {
    list-style: none;
    margin: 18px 0 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .features li {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-soft);
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .features li::before {
    content: '';
    flex-shrink: 0;
    width: 8px;
    height: 1px;
    background: var(--marmalade);
    transform: translateY(-4px);
  }

  .inline-cta {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--fern);
    border-bottom: 1px solid var(--marmalade);
    padding-bottom: 2px;
    transition: color 160ms ease;
  }
  .inline-cta:hover {
    color: var(--marmalade);
  }

  /* Section « Discutons » : card noire (permet les pills sur fond sombre). */
  .cta-card {
    background: var(--ink);
    border-radius: 24px;
    padding: clamp(32px, 5vw, 56px);
  }
  .cta-card h2 {
    color: var(--paper);
  }
  .cta-card p {
    color: var(--paper-soft);
  }
  .cta-card p strong {
    color: var(--paper);
  }

  /* Pills identiques à CtaFinal (section contact du site normal). */
  .cta-row {
    margin-top: 14px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 9999px;
    text-decoration: none;
    transition: background-color 200ms ease, color 200ms ease,
                border-color 200ms ease,
                transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .pill-arrow {
    width: 12px;
    height: 12px;
    display: inline-block;
    flex-shrink: 0;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .pill:hover .pill-arrow {
    transform: translate(2px, -2px);
  }
  .pill--primary {
    background: var(--marmalade);
    color: var(--paper);
  }
  .pill--primary:hover {
    background: var(--paper);
    color: var(--ink);
  }
  .pill--ghost {
    background: transparent;
    color: var(--paper-warm);
    border: 1px solid rgba(246, 240, 224, 0.3);
  }
  .pill--ghost:hover {
    border-color: var(--paper);
    color: var(--paper);
  }
</style>
