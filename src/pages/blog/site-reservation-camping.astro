---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import SubpageHeader from '../../components/SubpageHeader.astro';
import {
  SITE_URL,
  siteSoftwareApplication,
  buildBreadcrumb,
  buildWebPage,
} from '../../data/schema';

const title = 'Site de réservation camping en ligne sans commission · Camplo';
const description =
  "Camplo crée des sites de réservation en ligne pour campings indépendants du Québec. Paiement par carte Stripe intégré, confirmation automatique, aucune commission par réservation.";
const pageUrl = `${SITE_URL}/blog/site-reservation-camping/`;

const datePublished = '2026-04-25';
const datePublishedLabel = new Intl.DateTimeFormat('fr-CA', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
}).format(new Date(`${datePublished}T12:00:00`));

const pageJsonLd = [
  siteSoftwareApplication,
  buildWebPage({
    url: pageUrl,
    name: title,
    description,
    about: `${SITE_URL}/#site`,
    datePublished,
    dateModified: '2026-04-25',
  }),
  buildBreadcrumb([
    { name: 'Camplo', url: `${SITE_URL}/` },
    { name: 'Blog', url: `${SITE_URL}/blog/` },
    { name: 'Site de réservation camping', url: pageUrl },
  ]),
];
---

<Layout
  title={title}
  description={description}
  canonicalPath="/blog/site-reservation-camping/"
  ogImageAlt="Camplo : site de réservation camping en ligne sans commission pour campings québécois"
  includeFaqJsonLd={false}
  includeProductPreloads={false}
  pageJsonLd={pageJsonLd}
>
  <SubpageHeader backHref="/blog/" backLabel="Retour aux articles" />

  <main class="subpage">
    <article class="article">
      <p class="eyebrow">Produit · Site de réservation camping</p>
      <h1 class="title">
        Le site de <em>réservation camping</em> qui encaisse, pas qui commissionne
      </h1>
      <p class="article-meta">
        Publié le <time datetime={datePublished}>{datePublishedLabel}</time>
      </p>

      <p class="lede">
        Un site de réservation en ligne dédié à votre camping, branché à un
        terminal Stripe, qui transforme un visiteur curieux en réservation
        confirmée et payée, sans intermédiaire, sans commission, sans
        formulaire de douze pages.
      </p>

      <section class="section">
        <h2>Un site de réservation en ligne pensé pour le camping</h2>
        <p>
          La majorité des campings québécois envoient encore leurs réservations
          par téléphone, par courriel, ou via une plateforme tierce qui prend
          10 à 20&nbsp;% sur chaque transaction. Camplo crée un site de
          réservation camping <strong>qui vous appartient</strong>, hébergé à
          votre nom de domaine, pensé pour la spécificité d'un camping :
          emplacements, services, saisons, dates flexibles, services
          additionnels.
        </p>
        <ul class="features">
          <li>Réservation en ligne 24/7</li>
          <li>Paiement par carte (Stripe intégré)</li>
          <li>Confirmation automatique par courriel</li>
          <li>Aucune commission par réservation</li>
          <li>Design adapté à votre marque</li>
          <li>Mobile-first, rapide, conçu pour Google</li>
        </ul>
      </section>

      <section class="section">
        <h2>Zéro commission, peu importe le volume</h2>
        <p>
          Sur 200 réservations à 200&nbsp;$ avec une plateforme qui prend
          15&nbsp;%, vous laissez <strong>6&nbsp;000&nbsp;$ par mois</strong>
          sur la table. Camplo, c'est un abonnement mensuel fixe : vous savez
          d'avance ce que vous payez, peu importe que vous fassiez 50 ou 500
          réservations dans le mois. Vos profits restent les vôtres.
        </p>
      </section>

      <section class="section">
        <h2>Paiement par carte intégré (Stripe)</h2>
        <p>
          Stripe est le standard mondial du paiement en ligne. Aucun frais
          caché, des taux de transaction transparents (~2,9&nbsp;% +
          0,30&nbsp;$ par paiement), et l'argent est versé directement dans
          votre compte bancaire. Camplo s'occupe de l'intégration technique :
          vous donnez vos identifiants Stripe, on branche le tout.
        </p>
      </section>

      <section class="section">
        <h2>Confirmation automatique, suivi, rappels</h2>
        <p>
          Quand un campeur réserve et paie, tout part automatiquement :
          courriel de confirmation avec les détails du séjour, instructions
          d'arrivée, votre numéro de téléphone. Pas de saisie manuelle, pas
          d'oubli, pas de courriel à 22h après une journée de quinze heures.
        </p>
      </section>

      <section class="section">
        <h2>Couplé avec votre logiciel de gestion (CRM)</h2>
        <p>
          Le site de réservation peut tourner seul, mais il devient
          redoutable couplé avec le <a class="inline-cta" href="/blog/logiciel-gestion-camping/">logiciel de gestion camping Camplo</a>.
          Chaque réservation web apparaît instantanément dans votre tableau
          de bord, avec le nom du client, son emplacement, ses services. Une
          seule source de vérité, pas de double saisie.
        </p>
        <p>
          <a class="inline-cta" href="/">Voir tous les produits Camplo →</a>
        </p>
      </section>

      <section class="section cta-card">
        <h2>Discutons de votre projet</h2>
        <p>
          Chaque camping a sa réalité : nombre d'emplacements, types de
          services, formules saisonnières, dépôts requis. On adapte le site
          à votre opération. Premier appel sans engagement, on vous dit
          honnêtement si Camplo correspond à votre besoin.
        </p>
        <div class="cta-row">
          <a class="pill pill--primary" href="mailto:contact@tekio.ca">
            Écrivez-nous
            <svg class="pill-arrow" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
              <path d="M4 10 L10 4 M5 4 L10 4 L10 9" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
          <a class="pill pill--ghost" href="tel:5817480161">
            581-748-0161
            <svg class="pill-arrow" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
              <path d="M4 10 L10 4 M5 4 L10 4 L10 9" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      </section>
    </article>
  </main>

  <Footer />
</Layout>

<style>
  .subpage {
    background: var(--paper);
    padding: clamp(40px, 6vw, 80px) 0 clamp(60px, 8vw, 120px);
    min-height: 60vh;
  }

  .article {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 var(--wrap-pad-x);
  }

  .eyebrow {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--fern);
    margin-bottom: 18px;
  }

  .title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(36px, 5vw, 60px);
    letter-spacing: -0.025em;
    line-height: 1.05;
    color: var(--ink);
    margin: 0 0 14px;
  }
  .title em {
    font-style: italic;
    font-weight: 500;
    color: var(--marmalade);
  }

  .article-meta {
    font-family: var(--font-label);
    font-weight: 500;
    font-size: 13px;
    letter-spacing: 0.02em;
    color: var(--ink-muted);
    margin: 0 0 32px;
  }
  .article-meta time {
    color: var(--ink-soft);
  }

  .lede {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.45;
    color: var(--ink-soft);
    margin: 0 0 48px;
    max-width: 60ch;
  }

  .section {
    margin-top: clamp(40px, 5vw, 64px);
  }

  .section h2 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(24px, 2.6vw, 32px);
    letter-spacing: -0.015em;
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 16px;
  }

  .section p {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: clamp(15px, 1.05vw, 17px);
    line-height: 1.65;
    color: var(--ink-soft);
    margin: 0 0 14px;
    max-width: 62ch;
  }

  .section p strong {
    color: var(--ink);
    font-weight: 700;
  }

  .features {
    list-style: none;
    margin: 18px 0 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }
  .features li {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-soft);
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .features li::before {
    content: '';
    flex-shrink: 0;
    width: 8px;
    height: 1px;
    background: var(--marmalade);
    transform: translateY(-4px);
  }

  .inline-cta {
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--fern);
    border-bottom: 1px solid var(--marmalade);
    padding-bottom: 2px;
    transition: color 160ms ease;
  }
  .inline-cta:hover {
    color: var(--marmalade);
  }

  /* Section « Discutons » : card noire (permet les pills sur fond sombre). */
  .cta-card {
    background: var(--ink);
    border-radius: 24px;
    padding: clamp(32px, 5vw, 56px);
  }
  .cta-card h2 {
    color: var(--paper);
  }
  .cta-card p {
    color: var(--paper-soft);
  }
  .cta-card p strong {
    color: var(--paper);
  }

  /* Pills identiques à CtaFinal (section contact du site normal). */
  .cta-row {
    margin-top: 14px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    font-family: var(--font-label);
    font-weight: 600;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-radius: 9999px;
    text-decoration: none;
    transition: background-color 200ms ease, color 200ms ease,
                border-color 200ms ease,
                transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .pill-arrow {
    width: 12px;
    height: 12px;
    display: inline-block;
    flex-shrink: 0;
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }
  .pill:hover .pill-arrow {
    transform: translate(2px, -2px);
  }
  .pill--primary {
    background: var(--marmalade);
    color: var(--paper);
  }
  .pill--primary:hover {
    background: var(--paper);
    color: var(--ink);
  }
  .pill--ghost {
    background: transparent;
    color: var(--paper-warm);
    border: 1px solid rgba(246, 240, 224, 0.3);
  }
  .pill--ghost:hover {
    border-color: var(--paper);
    color: var(--paper);
  }
</style>
